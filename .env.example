# ============================================================================
# ADMVC Cloud — Variáveis de Ambiente
# ============================================================================
# Copiar este ficheiro para .env e preencher os valores

# ── Base de Dados (PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_URL=postgresql://user:password@host:5432/dbname
PRISMA_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Vercel Blob (upload de imagens) ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── Loyverse (integração cantina) ───────────────────────────────────────────
LOYVERSE_ACCESS_TOKEN=xxx

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
KV_REST_API_READ_ONLY_TOKEN=xxx
KV_REST_API_TOKEN=xxx
KV_REST_API_URL=https://xxx.upstash.io
KV_URL=rediss://xxx
REDIS_URL=rediss://xxx

# ── Resend (envio de emails) ────────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# ── Web Push (VAPID keys — gerar com: npx web-push generate-vapid-keys) ─
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admvcff@gmail.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── APIs externas (opcionais) ───────────────────────────────────────────────
YOUTUBE_API_KEY=xxx
SPOTIFY_CLIENT_ID=xxx
SPOTIFY_CLIENT_SECRET=xxx

# ── Google Calendar (sincronização de agendas pastorais) ──────────────
# JSON da chave do Service Account (criar em Google Cloud Console > IAM > Service Accounts)
GOOGLE_CALENDAR_CREDENTIALS={"type":"service_account","client_email":"xxx@xxx.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"}
# ID do calendário de destino (ex: xxxx@group.calendar.google.com ou "primary")
GOOGLE_CALENDAR_ID=primary
