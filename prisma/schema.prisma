// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  LEADER
  ADMIN
  FINANCE
  MANAGER // Novo - Vagner
}

model Membro {
  id Int @id @default(autoincrement())

  // 1. Identificação Pessoal
  avatar_file     String?
  first_name      String
  last_name       String
  email           String        @unique
  phone_1         String
  phone_2         String? // Opcional, nao aparece no cadastro
  birthdate       DateTime?
  gender          String?
  profession      String?
  father_name     String? // 2. Filiação Pai
  mother_name     String? // 2. Filiação Mãe
  escolaridade_id Int?
  escolaridade    Escolaridade? @relation(fields: [escolaridade_id], references: [id])
  conversion_date DateTime?
  password        String?

  // 2. Contacto e Morada
  address_1      String? // Rua
  address_2      String? // Complemento
  address_number String?
  postal_code    String?
  id_city        String?
  state          String?
  country        String? @default("Portugal")
  neighborhood   String?

  // 3. Familia
  marital_status String?
  nationality    String?
  tax_id         String? // NIF ou CPF
  id_card_number String? // Cartão de Cidadão / RG
  lang           String? @default("pt")

  // 4. Dados Eclesiásticos (Campos de Gestão)
  baptism_status  String?   @default("Não Batizado")
  baptism_date    DateTime?
  church_role     String?   @default("Membro") // Diácono, Presbítero, etc
  ministry        String?   @default("Geral") // Louvor, Infantil, etc
  entry_date      DateTime? @default(now())
  is_active       Boolean   @default(true)
  notes           String?   @db.Text
  previous_church String?

  companhamentos_visitantes AcompanhamentoVisitante[]

  // 5. Sistema e Status
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  status        String    @default("PENDENTE") // PENDENTE, ATIVO, ARQUIVADO
  data_admissao DateTime?
  aprovado_por  String? // Nome do Admin que aprovou

  // 6. Dados Matrimoniais e Filhos
  spouse_name      String? // Nome do Cônjuge
  spouse_christian Boolean?  @default(false)
  wedding_date     DateTime? // Data do Casamento
  has_children     Boolean?  @default(false)
  children_number  Int?      @default(0)

  // 7. Conexão com a Família
  familia_id      Int?
  familia         Familia? @relation(fields: [familia_id], references: [id])
  parentesco      String? // Ex: "Pai", "Mãe", "Filho(a)", "Cônjuge"
  is_family_admin Boolean  @default(false) // Se 'true', edita os outros da família

  // 8. RELAÇÕES (Corrigidas)
  cargos                  Cargo[]
  departamentos_liderados Departamento[]           @relation("LiderDepartamento")
  ministerios             IntegranteDepartamento[] // Substitui a antiga relação direta
  grupos                  Grupo[]                  @relation("MembrosGrupo")
  lider_de_grupo          Grupo[]                  @relation("LideresGrupo")
  escalas                 Escala[]

  //cargos                  IntegranteDepartamento[]
  ip_assinatura String?
  data_aceite   DateTime?
  termo_aceite  Boolean   @default(false)
  role          Role      @default(USER)

  // 9. Finanças
  objetivos_financeiros ObjetivoFinanceiro[]
  loyverse_id           String?              @unique
  rifa_numeros          RifaNumero[]
  pedidoSaldoCantinas   PedidoSaldoCantina[]
  contribuicoes         Contribuicao[]
  avisoMurals           AvisoMural[]

  // --- Documentação Legal e Interna ---
  gdpr_aceite          Boolean   @default(false)
  gdpr_data_assinatura DateTime?
  gdpr_validade        DateTime?

  permanecer_aceite          Boolean   @default(false)
  permanecer_data_assinatura DateTime?
  permanecer_validade        DateTime?

  encontros_assistidos EncontroGrupo[] @relation("MembrosPresentes")

  // Relações com a Agenda
  agenda_dono     Agenda?       @relation("DonoAgenda")
  agendas_geridas Agenda[]      @relation("GestoresAgenda")
  compromissos    Compromisso[] @relation("CompromissoMembros")

  @@map("membros")
}

model Familia {
  id         Int      @id @default(autoincrement())
  surname    String
  members    Membro[]
  created_at DateTime @default(now())
}

model Escolaridade {
  id      Int      @id @default(autoincrement())
  nome    String   @unique
  membros Membro[]

  @@map("escolaridades")
}

model Departamento {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?

  // Liderança
  lider_id Int?
  lider    Membro? @relation("LiderDepartamento", fields: [lider_id], references: [id])

  // Relações Corrigidas
  integrantes   IntegranteDepartamento[]
  grupos        Grupo[]
  escalas       Escala[]
  funcoes       FuncaoDepartamento[]
  avisoMurals   AvisoMural[]
  compromissos  Compromisso[]            @relation("CompromissoDepartamentos")
  compromissoId Int?
}

model IntegranteDepartamento {
  id Int @id @default(autoincrement())

  membro_id Int
  membro    Membro @relation(fields: [membro_id], references: [id], onDelete: Cascade)

  departamento_id Int
  departamento    Departamento @relation(fields: [departamento_id], references: [id], onDelete: Cascade)

  funcao String

  data_entrada DateTime @default(now())

  // Garante que a pessoa não é cadastrada duas vezes no mesmo departamento
  // Caso tenha várias funções, a principal/última fica salva aqui.
  @@unique([membro_id, departamento_id]) // Novo - Vagner
}

model Grupo {
  id            Int      @id @default(autoincrement())
  nome          String
  data_abertura DateTime @default(now())
  dia_semana    String
  horario       String
  perfil        String?
  categoria     String?
  descricao     String?

  // Localização
  endereco String
  numero   String?
  bairro   String
  cidade   String
  estado   String
  pais     String  @default("Portugal")

  // Relações
  departamento_id Int?
  departamento    Departamento? @relation(fields: [departamento_id], references: [id])

  lideres       Membro[]        @relation("LideresGrupo")
  membros       Membro[]        @relation("MembrosGrupo")
  avisoMurals   AvisoMural[]
  encontros     EncontroGrupo[]
  compromissos  Compromisso[]   @relation("CompromissoGrupos")
  compromissoId Int?
}

model EncontroGrupo {
  id       Int      @id @default(autoincrement())
  grupo_id Int
  data     DateTime
  tema     String   @db.Text
  foto_url String?

  grupo Grupo @relation(fields: [grupo_id], references: [id], onDelete: Cascade)

  presentes Membro[] @relation("MembrosPresentes")

  criado_em DateTime @default(now())
}

model Cargo {
  id      Int      @id @default(autoincrement())
  nome    String   @unique
  membros Membro[]
}

model Evento {
  id        Int      @id @default(autoincrement())
  nome      String
  data      DateTime
  descricao String?

  escalas       Escala[]
  repertorio    RepertorioEvento[]
  criado_em     DateTime           @default(now())
  atualizado_em DateTime           @updatedAt
}

model Escala {
  id         Int      @id @default(autoincrement())
  funcao     String
  confirmado Boolean  @default(false)
  horario    String?
  criado_em  DateTime @default(now())

  // Relações
  evento_id Int
  evento    Evento @relation(fields: [evento_id], references: [id], onDelete: Cascade)

  departamento_id Int
  departamento    Departamento @relation(fields: [departamento_id], references: [id], onDelete: Cascade)

  membro_id Int
  membro    Membro @relation(fields: [membro_id], references: [id], onDelete: Cascade)

  @@unique([evento_id, membro_id])
}

model FuncaoDepartamento {
  id              Int          @id @default(autoincrement())
  nome            String
  departamento_id Int
  departamento    Departamento @relation(fields: [departamento_id], references: [id], onDelete: Cascade)

  @@unique([nome, departamento_id])
}

model ObjetivoFinanceiro {
  id             Int    @id @default(autoincrement())
  nome           String
  valor_mensal   Float
  parcelas_total Int
  parcelas_pagas Int    @default(0)
  data_pagamento Int

  membro_id Int
  membro    Membro @relation(fields: [membro_id], references: [id])

  status      String                 @default("ATIVO")
  createdAt   DateTime               @default(now())
  lancamentos LancamentoFinanceiro[]
}

model LancamentoFinanceiro {
  id          Int                @id @default(autoincrement())
  objetivo_id Int
  objetivo    ObjetivoFinanceiro @relation(fields: [objetivo_id], references: [id])

  valor_pago       Float
  data_recebimento DateTime @default(now())
  forma_pagamento  String
  comprovante_url  String?

  registrado_por_id Int
}

model Rifa {
  id                Int          @id @default(autoincrement())
  nome              String
  premio            String
  valor_numero      Float
  total_numeros     Int
  data_sorteio      DateTime?
  status            String       @default("ATIVA")
  createdAt         DateTime     @default(now())
  numero_sorteado   Int?
  numeros_vendidos  RifaNumero[]
  numero_sorteado_2 Int?
  numero_sorteado_3 Int?
}

model RifaNumero {
  id     Int @id @default(autoincrement())
  numero Int

  rifa_id Int
  rifa    Rifa @relation(fields: [rifa_id], references: [id], onDelete: Cascade)

  membro_id Int?
  membro    Membro? @relation(fields: [membro_id], references: [id])

  nome_externo String? // Se o membro vendeu a um vizinho/amigo de fora da igreja
  pago         Boolean @default(true) // Regista se já pagou ou só reservou

  createdAt DateTime @default(now())

  @@unique([rifa_id, numero])
}

model PedidoSaldoCantina {
  id              Int      @id @default(autoincrement())
  membro_id       Int
  membro          Membro   @relation(fields: [membro_id], references: [id])
  valor           Float
  forma_pagamento String
  status          String   @default("PENDENTE")
  createdAt       DateTime @default(now())
}

model Contribuicao {
  id        Int    @id @default(autoincrement())
  membro_id Int
  membro    Membro @relation(fields: [membro_id], references: [id], onDelete: Cascade)

  tipo       String
  valor      Float
  data       DateTime @default(now())
  metodo     String?
  observacao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visitante {
  id                   Int      @id @default(autoincrement())
  nome                 String
  telefone             String
  pedido_oracao        String?  @db.Text
  email                String?
  data_primeira_visita DateTime @default(now())
  data_ultima_visita   DateTime @default(now())
  quantidade_visitas   Int      @default(1)
  status               String   @default("NOVO")

  acompanhamentos AcompanhamentoVisitante[]
  compromissos    Compromisso[]             @relation("CompromissoVisitantes")

  @@map("visitantes")
}

model AcompanhamentoVisitante {
  id            Int      @id @default(autoincrement())
  visitante_id  Int
  membro_id     Int
  tipo_contacto String
  observacoes   String?  @db.Text
  data_contacto DateTime @default(now())

  visitante Visitante @relation(fields: [visitante_id], references: [id], onDelete: Cascade)
  membro    Membro    @relation(fields: [membro_id], references: [id])

  @@map("acompanhamento_visitantes")
}

model ProjetoObra {
  id            String      @id @default(cuid())
  titulo        String
  descricao     String
  objetivoFinal Float
  videoUrl      String?
  etapas        EtapaObra[]
}

model EtapaObra {
  id              String      @id @default(cuid())
  projeto_obra_id String
  projeto         ProjetoObra @relation(fields: [projeto_obra_id], references: [id], onDelete: Cascade)
  nome            String
  alvo            Float
  atual           Float       @default(0)
  ordem           Int         @default(0)
}

model AvisoMural {
  id        String   @id @default(cuid())
  texto     String   @db.Text
  createdAt DateTime @default(now())

  autor_id Int
  autor    Membro @relation(fields: [autor_id], references: [id], onDelete: Cascade)

  // Nota: Se os IDs dos seus Departamentos/Grupos forem String (cuid/uuid), mude Int? para String?
  departamento_id Int?
  departamento    Departamento? @relation(fields: [departamento_id], references: [id], onDelete: Cascade)

  grupo_id Int?
  grupo    Grupo? @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
}

model Agenda {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  nome       String
  is_publica Boolean @default(true)

  dono_id Int    @unique
  dono    Membro @relation("DonoAgenda", fields: [dono_id], references: [id], onDelete: Cascade)

  gestores Membro[] @relation("GestoresAgenda")

  compromissos Compromisso[]

  criado_em DateTime @default(now())
}

model Compromisso {
  id          Int      @id @default(autoincrement())
  titulo      String
  categoria   String
  data_inicio DateTime
  data_fim    DateTime
  observacoes String?
  status      String   @default("AGENDADO")

  agenda_id Int
  agenda    Agenda @relation(fields: [agenda_id], references: [id], onDelete: Cascade)

  membros       Membro[]       @relation("CompromissoMembros")
  visitantes    Visitante[]    @relation("CompromissoVisitantes")
  departamentos Departamento[] @relation("CompromissoDepartamentos")

  externos String?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  grupos Grupo[] @relation("CompromissoGrupos")
}

model Musica {
  id          String  @id @default(uuid())
  titulo      String
  artista     String?
  bpm         Int?
  link_video  String? // Link do YouTube/Spotify
  holyrics_id String? @unique // <--- ADICIONE ESTA LINHA

  // Relação com os eventos (O repertório)
  eventos RepertorioEvento[]
}

model RepertorioEvento {
  id        String @id @default(uuid())
  evento_id Int // <-- CORRIGIDO AQUI: Mudou de String para Int
  evento    Evento @relation(fields: [evento_id], references: [id])

  musica_id String
  musica    Musica @relation(fields: [musica_id], references: [id])

  tom_tocado String // Ex: "G", "C#m" - O tom escolhido para ESTE culto
  ordem      Int // 1, 2, 3 (Para ordenar as músicas no culto)

  @@unique([evento_id, musica_id]) // Evita a mesma música duplicada no mesmo culto
}
