generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Escolaridade {
  id      Int      @id @default(autoincrement())
  nome    String   @unique
  membros Membro[]

  @@map("escolaridades")
}

model Cargo {
  id      Int      @id @default(autoincrement())
  nome    String   @unique
  membros Membro[] @relation("CargoToMembro")
}

model Musica {
  id          String             @id @default(uuid())
  titulo      String
  artista     String?
  bpm         Int?
  tom         String? // Tom original da musica (Ex: "G", "Am", "F#")
  link_video  String? // YouTube
  link_letra  String? // letras.mus.br, letras.com
  link_cifra  String? // cifraclub.com.br, ultimate-guitar.com
  link_audio  String? // Spotify, SoundCloud, YouTube Music
  cifra_interna String? // Cifra com acordes no formato [Am]letra[G]letra
  holyrics_id String?            @unique
  eventos     RepertorioEvento[]

  @@map("musicas")
}

model Tenant {
  id                       Int                       @id @default(autoincrement())
  slug                     String                    @unique
  nome                     String
  plano                    String                    @default("FREE")
  modulos_custom           Json?                     // Override de módulos activos (array de strings). Se null, usa os do plano.
  cor_primaria             String                    @default("#3F6B4F")
  cor_secundaria           String                    @default("#7FAE93")
  cor_fundo                String                    @default("#0b0d0c")
  logo_url                 String?
  // Configuracoes de midia
  holyrics_url             String?                   // Ex: http://192.168.1.100:8090
  holyrics_token           String?
  x32_ip                   String?                   // Ex: 192.168.1.50
  x32_port                 Int?                      @default(10023)
  lumikit_url              String?                   // Ex: http://192.168.1.60
  createdAt                DateTime                  @default(now())
  agendas                  Agenda[]
  avisosMural              AvisoMural[]
  compromissos             Compromisso[]
  congregacoes             Congregacao[]
  contribuicoes            Contribuicao[]
  departamentos            Departamento[]
  encontros                EncontroGrupo[]
  escalas                  Escala[]
  etapasObra               EtapaObra[]
  eventos                  Evento[]
  familias                 Familia[]
  funcoesDepto             FuncaoDepartamento[]
  grupos                   Grupo[]
  integrantesDepto         IntegranteDepartamento[]
  lancamentosFinanceiros   LancamentoFinanceiro[]
  objetivosFinanceiros     ObjetivoFinanceiro[]
  pedidosCantina           PedidoSaldoCantina[]
  projetosObra             ProjetoObra[]
  repertorios              RepertorioEvento[]
  rifas                    Rifa[]
  rifaNumeros              RifaNumero[]
  acompanhamentos          AcompanhamentoVisitante[]
  membros                  Membro[]
  visitantes               Visitante[]
  indisponibilidadeMembros IndisponibilidadeMembro[]
  mensagemEventos          MensagemEvento[]
  audit_logs               AuditLog[]
  itemInventarios          ItemInventario[]
  movimentosInventario     MovimentoInventario[]
}

model Congregacao {
  id            Int                    @id @default(autoincrement())
  nome          String
  cidade        String
  endereco      String
  tenant_id     Int
  createdAt     DateTime               @default(now())
  tenant              Tenant                 @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  departamentos       Departamento[]
  grupos              Grupo[]
  financas            LancamentoFinanceiro[]
  membros             Membro[]
  eventos             Evento[]
  escalas             Escala[]
  repertorios         RepertorioEvento[]
  indisponibilidades  IndisponibilidadeMembro[]
  mensagensEvento     MensagemEvento[]
  itensInventario     ItemInventario[]
  movimentosInventario MovimentoInventario[]
}

model Membro {
  id                         Int                       @id @default(autoincrement())
  first_name                 String
  last_name                  String
  email                      String                    @unique
  password                   String?
  avatar_file                String?
  birthdate                  DateTime?
  gender                     String?
  marital_status             String?
  nationality                String?
  tax_id                     String?
  id_card_number             String?
  profession                 String?
  lang                       String?                   @default("Português")
  father_name                String?
  mother_name                String?
  phone_1                    String
  phone_2                    String?
  address_1                  String?
  address_2                  String?
  address_number             String?
  postal_code                String?
  id_city                    String?
  state                      String?
  country                    String?                   @default("Portugal")
  baptism_status             String?                   @default("Não Batizado")
  baptism_date               DateTime?
  church_role                String?                   @default("Membro")
  ministry                   String?                   @default("Geral")
  entry_date                 DateTime?                 @default(now())
  is_active                  Boolean                   @default(true)
  notes                      String?
  previous_church            String?
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime                  @updatedAt
  status                     String                    @default("PENDENTE")
  data_admissao              DateTime?
  aprovado_por               String?
  spouse_name                String?
  spouse_christian           Boolean?                  @default(false)
  wedding_date               DateTime?
  has_children               Boolean?                  @default(false)
  children_number            Int?                      @default(0)
  familia_id                 Int?
  parentesco                 String?
  is_family_admin            Boolean                   @default(false)
  ip_assinatura              String?
  data_aceite                DateTime?
  termo_aceite               Boolean                   @default(false)
  role                       Role                      @default(USER)
  loyverse_id                String?                   @unique
  conversion_date            DateTime?
  escolaridade_id            Int?
  congregacao_id             Int?
  gdpr_aceite                Boolean                   @default(false)
  gdpr_data_assinatura       DateTime?
  gdpr_validade              DateTime?
  neighborhood               String?
  permanecer_aceite          Boolean                   @default(false)
  permanecer_data_assinatura DateTime?
  permanecer_validade        DateTime?
  tenant_id                  Int
  agenda_dono                Agenda?                   @relation("DonoAgenda")
  avisoMurals                AvisoMural[]
  contribuicoes              Contribuicao[]
  departamentos_liderados    Departamento[]            @relation("LiderDepartamento")
  escalas                    Escala[]
  ministerios                IntegranteDepartamento[]
  objetivos_financeiros      ObjetivoFinanceiro[]
  pedidoSaldoCantinas        PedidoSaldoCantina[]
  rifa_numeros               RifaNumero[]
  companhamentos_visitantes  AcompanhamentoVisitante[]
  congregacao                Congregacao?              @relation(fields: [congregacao_id], references: [id])
  escolaridade               Escolaridade?             @relation(fields: [escolaridade_id], references: [id])
  familia                    Familia?                  @relation(fields: [familia_id], references: [id])
  tenant                     Tenant                    @relation(fields: [tenant_id], references: [id])
  cargos                     Cargo[]                   @relation("CargoToMembro")
  compromissos               Compromisso[]             @relation("CompromissoMembros")
  agendas_geridas            Agenda[]                  @relation("GestoresAgenda")
  lider_de_grupo             Grupo[]                   @relation("LideresGrupo")
  grupos                     Grupo[]                   @relation("MembrosGrupo")
  encontros_assistidos       EncontroGrupo[]           @relation("MembrosPresentes")
  indisponibilidadeMembros   IndisponibilidadeMembro[]
  mensagemEventos            MensagemEvento[]
  itemInventarios            ItemInventario[]

  @@index([tenant_id])
  @@map("membros")
}

model Familia {
  id         Int      @id @default(autoincrement())
  surname    String
  created_at DateTime @default(now())
  tenant_id  Int
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  members    Membro[]

  @@index([tenant_id])
}

model Departamento {
  id               Int                      @id @default(autoincrement())
  nome             String
  descricao        String?
  lider_id         Int?
  compromissoId    Int?
  congregacaoId    Int?
  is_global        Boolean                  @default(false)
  tenant_id        Int
  avisoMurals      AvisoMural[]
  congregacao      Congregacao?             @relation(fields: [congregacaoId], references: [id])
  lider            Membro?                  @relation("LiderDepartamento", fields: [lider_id], references: [id])
  tenant           Tenant                   @relation(fields: [tenant_id], references: [id])
  escalas          Escala[]
  funcoes          FuncaoDepartamento[]
  grupos           Grupo[]
  integrantes      IntegranteDepartamento[]
  compromissos     Compromisso[]            @relation("CompromissoDepartamentos")
  itens_inventario ItemInventario[]

  @@unique([nome, tenant_id, congregacaoId])
  @@index([tenant_id])
}

model IntegranteDepartamento {
  id                 Int                 @id @default(autoincrement())
  membro_id          Int
  departamento_id    Int
  data_entrada       DateTime            @default(now())
  pode_gerir_escalas Boolean             @default(false)
  tenant_id          Int
  funcoes            FuncaoSelecionada[]
  departamento       Departamento        @relation(fields: [departamento_id], references: [id], onDelete: Cascade)
  membro             Membro              @relation(fields: [membro_id], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenant_id], references: [id])

  @@unique([membro_id, departamento_id])
  @@index([tenant_id])
}

model FuncaoSelecionada {
  id                         Int                    @id @default(autoincrement())
  integrante_departamento_id Int
  funcao_id                  Int
  funcao                     FuncaoDepartamento     @relation(fields: [funcao_id], references: [id])
  integrante                 IntegranteDepartamento @relation(fields: [integrante_departamento_id], references: [id], onDelete: Cascade)
}

model Grupo {
  id              Int              @id @default(autoincrement())
  nome            String
  data_abertura   DateTime         @default(now())
  dia_semana      String
  horario         String
  perfil          String?
  categoria       String?
  descricao       String?
  endereco        String
  numero          String?
  bairro          String
  cidade          String
  estado          String
  pais            String           @default("Portugal")
  departamento_id Int?
  compromissoId   Int?
  congregacaoId   Int?
  tenant_id       Int
  latitude        Float?
  longitude       Float?
  regiao          String? // Ex: "Norte", "Centro", "Sul", "Online"
  publico         Boolean          @default(false) // aparece no site público?
  avisoMurals     AvisoMural[]
  encontros       EncontroGrupo[]
  congregacao     Congregacao?     @relation(fields: [congregacaoId], references: [id])
  departamento    Departamento?    @relation(fields: [departamento_id], references: [id])
  tenant          Tenant           @relation(fields: [tenant_id], references: [id])
  compromissos    Compromisso[]    @relation("CompromissoGrupos")
  lideres         Membro[]         @relation("LideresGrupo")
  membros         Membro[]         @relation("MembrosGrupo")
  itemInventarios ItemInventario[]

  @@index([tenant_id])
}

model EncontroGrupo {
  id        Int      @id @default(autoincrement())
  tenant_id Int
  grupo_id  Int
  data      DateTime
  tema      String
  foto_url  String?
  criado_em DateTime @default(now())
  grupo     Grupo    @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenant_id], references: [id])
  presentes Membro[] @relation("MembrosPresentes")
  latitude  Float?
  longitude Float?
  regiao    String? // Ex: "Norte", "Centro", "Sul", "Online"
  publico   Boolean  @default(false) // aparece no site público?

  @@index([tenant_id])
}

model Evento {
  id             Int                @id @default(autoincrement())
  nome           String
  data           DateTime
  descricao      String?
  criado_em      DateTime           @default(now())
  atualizado_em  DateTime           @updatedAt
  tenant_id      Int
  congregacao_id Int?
  escalas        Escala[]
  tenant         Tenant             @relation(fields: [tenant_id], references: [id])
  congregacao    Congregacao?       @relation(fields: [congregacao_id], references: [id])
  repertorio     RepertorioEvento[]
  mensagemEvento MensagemEvento?

  @@index([tenant_id])
}

model Escala {
  id              Int                 @id @default(autoincrement())
  funcao          String
  confirmado      Boolean             @default(false)
  horario         String?
  criado_em       DateTime            @default(now())
  evento_id       Int
  departamento_id Int
  membro_id       Int
  tenant_id       Int
  congregacao_id  Int?
  funcao_id       Int?
  departamento    Departamento        @relation(fields: [departamento_id], references: [id], onDelete: Cascade)
  evento          Evento              @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  funcao_ref      FuncaoDepartamento? @relation(fields: [funcao_id], references: [id])
  membro          Membro              @relation(fields: [membro_id], references: [id], onDelete: Cascade)
  tenant          Tenant              @relation(fields: [tenant_id], references: [id])
  congregacao     Congregacao?        @relation(fields: [congregacao_id], references: [id])
  motivo_recusa   String?

  @@unique([evento_id, membro_id, funcao_id])
  @@index([tenant_id])
}

model FuncaoDepartamento {
  id                 Int                 @id @default(autoincrement())
  nome               String
  departamento_id    Int
  tenant_id          Int
  escalas            Escala[]
  departamento       Departamento        @relation(fields: [departamento_id], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenant_id], references: [id])
  funcaoSelecionadas FuncaoSelecionada[]

  @@unique([nome, departamento_id])
  @@index([tenant_id])
}

model ObjetivoFinanceiro {
  id             Int                    @id @default(autoincrement())
  nome           String
  valor_mensal   Float
  parcelas_total Int
  parcelas_pagas Int                    @default(0)
  data_pagamento Int
  membro_id      Int
  status         String                 @default("ATIVO")
  createdAt      DateTime               @default(now())
  tenant_id      Int
  lancamentos    LancamentoFinanceiro[]
  membro         Membro                 @relation(fields: [membro_id], references: [id])
  tenant         Tenant                 @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model LancamentoFinanceiro {
  id                Int                @id @default(autoincrement())
  objetivo_id       Int
  valor_pago        Float
  data_recebimento  DateTime           @default(now())
  forma_pagamento   String
  comprovante_url   String?
  registrado_por_id Int
  congregacaoId     Int?
  tenant_id         Int
  congregacao       Congregacao?       @relation(fields: [congregacaoId], references: [id])
  objetivo          ObjetivoFinanceiro @relation(fields: [objetivo_id], references: [id])
  tenant            Tenant             @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model Rifa {
  id                Int          @id @default(autoincrement())
  nome              String
  premio            String
  valor_numero      Float
  total_numeros     Int
  data_sorteio      DateTime?
  status            String       @default("ATIVA")
  createdAt         DateTime     @default(now())
  numero_sorteado   Int?
  numero_sorteado_2 Int?
  numero_sorteado_3 Int?
  tenant_id         Int
  tenant            Tenant       @relation(fields: [tenant_id], references: [id])
  numeros_vendidos  RifaNumero[]

  @@index([tenant_id])
}

model RifaNumero {
  id           Int      @id @default(autoincrement())
  numero       Int
  rifa_id      Int
  membro_id    Int?
  nome_externo String?
  pago         Boolean  @default(true)
  createdAt    DateTime @default(now())
  tenant_id    Int
  membro       Membro?  @relation(fields: [membro_id], references: [id])
  rifa         Rifa     @relation(fields: [rifa_id], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([rifa_id, numero])
  @@index([tenant_id])
}

model PedidoSaldoCantina {
  id              Int      @id @default(autoincrement())
  membro_id       Int
  valor           Float
  forma_pagamento String
  status          String   @default("PENDENTE")
  createdAt       DateTime @default(now())
  tenant_id       Int
  membro          Membro   @relation(fields: [membro_id], references: [id])
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model Contribuicao {
  id         Int      @id @default(autoincrement())
  membro_id  Int
  tipo       String
  valor      Float
  data       DateTime @default(now())
  metodo     String?
  observacao String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant_id  Int
  membro     Membro   @relation(fields: [membro_id], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model Visitante {
  id                   Int                       @id @default(autoincrement())
  nome                 String
  telefone             String
  pedido_oracao        String?
  data_primeira_visita DateTime                  @default(now())
  data_ultima_visita   DateTime                  @default(now())
  quantidade_visitas   Int                       @default(1)
  status               String                    @default("NOVO")
  email                String?
  tenant_id            Int
  acompanhamentos      AcompanhamentoVisitante[]
  tenant               Tenant                    @relation(fields: [tenant_id], references: [id])
  compromissos         Compromisso[]             @relation("CompromissoVisitantes")

  @@index([tenant_id])
  @@map("visitantes")
}

model AcompanhamentoVisitante {
  id            Int       @id @default(autoincrement())
  visitante_id  Int
  membro_id     Int
  tipo_contacto String
  observacoes   String?
  data_contacto DateTime  @default(now())
  tenant_id     Int
  membro        Membro    @relation(fields: [membro_id], references: [id])
  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
  visitante     Visitante @relation(fields: [visitante_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("acompanhamento_visitantes")
}

model ProjetoObra {
  id            String      @id @default(cuid())
  titulo        String
  descricao     String
  objetivoFinal Float
  videoUrl      String?
  tenant_id     Int
  etapas        EtapaObra[]
  tenant        Tenant      @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model EtapaObra {
  id              String      @id @default(cuid())
  projeto_obra_id String
  nome            String
  alvo            Float
  atual           Float       @default(0)
  ordem           Int         @default(0)
  tenant_id       Int
  projeto         ProjetoObra @relation(fields: [projeto_obra_id], references: [id], onDelete: Cascade)
  tenant          Tenant      @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model AvisoMural {
  id              String        @id @default(cuid())
  texto           String
  createdAt       DateTime      @default(now())
  autor_id        Int
  departamento_id Int?
  grupo_id        Int?
  tenant_id       Int
  autor           Membro        @relation(fields: [autor_id], references: [id], onDelete: Cascade)
  departamento    Departamento? @relation(fields: [departamento_id], references: [id], onDelete: Cascade)
  grupo           Grupo?        @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model Agenda {
  id           Int           @id @default(autoincrement())
  tenant_id    Int
  slug         String        @unique
  nome         String
  is_publica   Boolean       @default(true)
  dono_id      Int           @unique
  criado_em    DateTime      @default(now())
  dono         Membro        @relation("DonoAgenda", fields: [dono_id], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenant_id], references: [id])
  compromissos Compromisso[]
  gestores     Membro[]      @relation("GestoresAgenda")

  @@index([tenant_id])
}

model Compromisso {
  id            Int            @id @default(autoincrement())
  tenant_id     Int
  titulo        String
  categoria     String
  data_inicio   DateTime
  data_fim      DateTime
  observacoes   String?
  status        String         @default("AGENDADO")
  agenda_id     Int
  externos      String?
  criado_em     DateTime       @default(now())
  atualizado_em DateTime       @updatedAt
  agenda        Agenda         @relation(fields: [agenda_id], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenant_id], references: [id])
  departamentos Departamento[] @relation("CompromissoDepartamentos")
  grupos        Grupo[]        @relation("CompromissoGrupos")
  membros       Membro[]       @relation("CompromissoMembros")
  visitantes    Visitante[]    @relation("CompromissoVisitantes")

  @@index([tenant_id])
}

model RepertorioEvento {
  id         String @id @default(uuid())
  tenant_id      Int
  congregacao_id Int?
  evento_id      Int
  musica_id      String
  tom_tocado     String
  ordem          Int
  evento         Evento       @relation(fields: [evento_id], references: [id])
  musica         Musica       @relation(fields: [musica_id], references: [id])
  tenant         Tenant       @relation(fields: [tenant_id], references: [id])
  congregacao    Congregacao? @relation(fields: [congregacao_id], references: [id])

  @@unique([evento_id, musica_id])
  @@index([tenant_id])
}

enum Role {
  USER
  LEADER
  ADMIN
  CONGREGATION_ADMIN
  FINANCE
  MANAGER
}

// ── SUPER ADMIN (Plataforma SaaS — independente dos tenants) ────────────────
model SuperAdmin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nome      String
  is_active Boolean  @default(true)
  criado_em DateTime @default(now())

  @@map("super_admins")
}

// NOVOS

// PATCH: schema.prisma
// Adiciona o model IndisponibilidadeMembro

model IndisponibilidadeMembro {
  id          Int       @id @default(autoincrement())
  tenant_id      Int
  congregacao_id Int?
  membro_id      Int
  tipo           String // 'DIA_SEMANA' | 'DATA_ESPECIFICA' | 'INTERVALO'
  dia_semana  Int? // 0=Dom, 1=Seg, ..., 6=Sáb (para DIA_SEMANA)
  data_inicio DateTime? // para DATA_ESPECIFICA e INTERVALO
  data_fim    DateTime? // para INTERVALO (null em DATA_ESPECIFICA)
  hora_inicio String? // ex: "08:00" — indisponível ANTES desta hora
  hora_fim    String? // ex: "18:00" — indisponível DEPOIS desta hora
  motivo      String?
  criado_em   DateTime  @default(now())

  membro      Membro       @relation(fields: [membro_id], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenant_id], references: [id])
  congregacao Congregacao?  @relation(fields: [congregacao_id], references: [id])

  @@index([tenant_id])
  @@index([membro_id])
  @@map("indisponibilidades_membro")
}

// No model Membro, adicionar:
// indisponibilidades IndisponibilidadeMembro[]

// Após editar o schema, correr:
// npx prisma migrate dev --name add_indisponibilidade_membro

model MensagemEvento {
  id             Int      @id @default(autoincrement())
  tenant_id      Int
  congregacao_id Int?
  evento_id      Int      @unique // um evento tem uma mensagem
  pregador_id    Int?
  titulo         String?
  texto_biblico  String? // ex: "João 3:16"
  tema           String?
  notas          String? // esboço livre
  criado_em      DateTime @default(now())
  atualizado_em  DateTime @updatedAt

  evento      Evento       @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  pregador    Membro?      @relation(fields: [pregador_id], references: [id])
  tenant      Tenant       @relation(fields: [tenant_id], references: [id])
  congregacao Congregacao?  @relation(fields: [congregacao_id], references: [id])

  @@index([tenant_id])
  @@map("mensagens_evento")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  actor_id    Int? // quem executou a accao (admin/membro logado)
  actor_nome  String? // nome snapshot (para manter historico se membro for apagado)
  alvo_id     Int? // sobre quem recaiu a accao
  alvo_nome   String? // nome snapshot do alvo
  alvo_tipo   String? // 'MEMBRO' | 'FAMILIA' | 'ESCALA' | 'FINANCEIRO' | 'SISTEMA'
  acao        String // 'CRIAR' | 'EDITAR' | 'APAGAR' | 'LOGIN' | 'LOGOUT' | 'EXPORT' | 'VINCULAR' | 'DESASSOCIAR'
  categoria   String // 'MEMBROS' | 'FAMILIAS' | 'ESCALAS' | 'FINANCEIRO' | 'ACESSO' | 'DOCUMENTOS'
  descricao   String? // texto legivel: "Alterou email de Joao Silva de X para Y"
  dados_antes String? // JSON snapshot antes da alteracao (campos alterados)
  dados_apos  String? // JSON snapshot apos a alteracao
  ip          String?
  user_agent  String?
  criado_em   DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([actor_id])
  @@index([alvo_id])
  @@index([acao])
  @@index([categoria])
  @@index([criado_em])
  @@map("audit_logs")
}

enum InventarioCategoria {
  ELETRONICO // equipamentos AV, microfones, computadores
  INSTRUMENTO // guitarras, teclados, baterias
  MOVEL // mesas, cadeiras, armários
  VEICULO // carros, vans da igreja
  FERRAMENTA // ferramentas de manutenção
  VESTUARIO // roupas, fardamentos
  LIVRO // bíblias, materiais didáticos
  CONSUMIVEL // material de escritório, limpeza
  OUTRO
}

enum InventarioEstado {
  OTIMO // novo ou como novo
  BOM // uso normal, sem danos
  REGULAR // desgaste visível mas funcional
  DANIFICADO // precisa de reparação
  INUTILIZAVEL // fora de uso
}

enum MovimentoTipo {
  ENTRADA // novo item adicionado
  SAIDA // item retirado/descartado
  EMPRESTIMO // saiu temporariamente
  DEVOLUCAO // voltou de empréstimo
  MANUTENCAO // entrou em manutenção
  RETORNO_MANUTENCAO // voltou da manutenção
  TRANSFERENCIA // mudou de dono/local
  AJUSTE // correcção de stock
}

// ── MODEL PRINCIPAL ───────────────────────────────────────────────────────────

model ItemInventario {
  id                Int                 @id @default(autoincrement())
  tenant_id         Int
  congregacao_id    Int?
  nome              String
  descricao         String?
  categoria         InventarioCategoria @default(OUTRO)
  estado            InventarioEstado    @default(BOM)
  numero_serie      String?
  codigo_patrimonio String?             @unique // código interno da igreja
  marca             String?
  modelo            String?
  cor               String?

  // Estoque
  quantidade_total      Int @default(1)
  quantidade_disponivel Int @default(1)

  // Aquisição
  data_aquisicao  DateTime?
  valor_aquisicao Float?
  fornecedor      String?
  nota_fiscal     String?

  // Garantia
  tem_garantia      Boolean   @default(false)
  garantia_validade DateTime?
  garantia_info     String? // nome da assistência, contrato, etc.

  // Localização física
  localizacao String? // ex: "Sala de Louvor", "Armazém"

  // Foto
  foto_url String?

  // Dono — pode ser departamento, grupo ou membro (apenas um)
  dono_tipo            String? // "DEPARTAMENTO" | "GRUPO" | "MEMBRO" | "IGREJA"
  dono_departamento_id Int?
  dono_grupo_id        Int?
  dono_membro_id       Int?

  // Metadados
  ativo      Boolean  @default(true)
  notas      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  tenant            Tenant                @relation(fields: [tenant_id], references: [id])
  congregacao       Congregacao?          @relation(fields: [congregacao_id], references: [id])
  dono_departamento Departamento?         @relation(fields: [dono_departamento_id], references: [id])
  dono_grupo        Grupo?                @relation(fields: [dono_grupo_id], references: [id])
  dono_membro       Membro?               @relation(fields: [dono_membro_id], references: [id])
  movimentos        MovimentoInventario[]

  @@index([tenant_id])
  @@index([categoria])
  @@index([dono_departamento_id])
  @@index([dono_grupo_id])
  @@index([dono_membro_id])
  @@map("inventario_itens")
}

// ── MOVIMENTOS / HISTÓRICO ────────────────────────────────────────────────────

model MovimentoInventario {
  id                    Int           @id @default(autoincrement())
  tenant_id             Int
  congregacao_id        Int?
  item_id               Int
  tipo                  MovimentoTipo
  quantidade            Int           @default(1)
  data                  DateTime      @default(now())
  responsavel           String? // nome ou ID de quem fez a movimentação
  destino               String? // para empréstimos: nome/local de destino
  data_retorno_prevista DateTime? // para empréstimos
  data_retorno_real     DateTime? // quando voltou
  observacao            String?
  created_at            DateTime      @default(now())

  item        ItemInventario @relation(fields: [item_id], references: [id], onDelete: Cascade)
  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  congregacao Congregacao?   @relation(fields: [congregacao_id], references: [id])

  @@index([item_id])
  @@index([tenant_id])
  @@map("inventario_movimentos")
}
