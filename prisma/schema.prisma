// PATCH: schema.prisma
// Adiciona o model IndisponibilidadeMembro

model IndisponibilidadeMembro {
  id          Int       @id @default(autoincrement())
  tenant_id      Int
  congregacao_id Int?
  membro_id      Int
  tipo           String // 'DIA_SEMANA' | 'DATA_ESPECIFICA' | 'INTERVALO'
  dia_semana  Int? // 0=Dom, 1=Seg, ..., 6=Sáb (para DIA_SEMANA)
  data_inicio DateTime? // para DATA_ESPECIFICA e INTERVALO
  data_fim    DateTime? // para INTERVALO (null em DATA_ESPECIFICA)
  hora_inicio String? // ex: "08:00" — indisponível ANTES desta hora
  hora_fim    String? // ex: "18:00" — indisponível DEPOIS desta hora
  motivo      String?
  criado_em   DateTime  @default(now())

  membro      Membro       @relation(fields: [membro_id], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenant_id], references: [id])
  congregacao Congregacao?  @relation(fields: [congregacao_id], references: [id])

  @@index([tenant_id])
  @@index([membro_id])
  @@map("indisponibilidades_membro")
}

// No model Membro, adicionar:
// indisponibilidades IndisponibilidadeMembro[]

// Após editar o schema, correr:
// npx prisma migrate dev --name add_indisponibilidade_membro

model MensagemEvento {
  id             Int      @id @default(autoincrement())
  tenant_id      Int
  congregacao_id Int?
  evento_id      Int      @unique // um evento tem uma mensagem
  pregador_id    Int?
  titulo         String?
  texto_biblico  String? // ex: "João 3:16"
  tema           String?
  notas          String? // esboço livre
  criado_em      DateTime @default(now())
  atualizado_em  DateTime @updatedAt

  evento      Evento       @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  pregador    Membro?      @relation(fields: [pregador_id], references: [id])
  tenant      Tenant       @relation(fields: [tenant_id], references: [id])
  congregacao Congregacao?  @relation(fields: [congregacao_id], references: [id])

  @@index([tenant_id])
  @@map("mensagens_evento")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  actor_id    Int? // quem executou a accao (admin/membro logado)
  actor_nome  String? // nome snapshot (para manter historico se membro for apagado)
  alvo_id     Int? // sobre quem recaiu a accao
  alvo_nome   String? // nome snapshot do alvo
  alvo_tipo   String? // 'MEMBRO' | 'FAMILIA' | 'ESCALA' | 'FINANCEIRO' | 'SISTEMA'
  acao        String // 'CRIAR' | 'EDITAR' | 'APAGAR' | 'LOGIN' | 'LOGOUT' | 'EXPORT' | 'VINCULAR' | 'DESASSOCIAR'
  categoria   String // 'MEMBROS' | 'FAMILIAS' | 'ESCALAS' | 'FINANCEIRO' | 'ACESSO' | 'DOCUMENTOS'
  descricao   String? // texto legivel: "Alterou email de Joao Silva de X para Y"
  dados_antes String? // JSON snapshot antes da alteracao (campos alterados)
  dados_apos  String? // JSON snapshot apos a alteracao
  ip          String?
  user_agent  String?
  hash        String?  // SHA-256 truncado — integridade do registo
  criado_em   DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([actor_id])
  @@index([alvo_id])
  @@index([acao])
  @@index([categoria])
  @@index([criado_em])
  @@map("audit_logs")
}

enum InventarioCategoria {
  ELETRONICO // equipamentos AV, microfones, computadores
  INSTRUMENTO // guitarras, teclados, baterias
  MOVEL // mesas, cadeiras, armários
  VEICULO // carros, vans da igreja
  FERRAMENTA // ferramentas de manutenção
  VESTUARIO // roupas, fardamentos
  LIVRO // bíblias, materiais didáticos
  CONSUMIVEL // material de escritório, limpeza
  OUTRO
}

enum InventarioEstado {
  OTIMO // novo ou como novo
  BOM // uso normal, sem danos
  REGULAR // desgaste visível mas funcional
  DANIFICADO // precisa de reparação
  INUTILIZAVEL // fora de uso
}

enum MovimentoTipo {
  ENTRADA // novo item adicionado
  SAIDA // item retirado/descartado
  EMPRESTIMO // saiu temporariamente
  DEVOLUCAO // voltou de empréstimo
  MANUTENCAO // entrou em manutenção
  RETORNO_MANUTENCAO // voltou da manutenção
  TRANSFERENCIA // mudou de dono/local
  AJUSTE // correcção de stock
}

// ── MODEL PRINCIPAL ───────────────────────────────────────────────────────────

model ItemInventario {
  id                Int                 @id @default(autoincrement())
  tenant_id         Int
  congregacao_id    Int?
  nome              String
  descricao         String?
  categoria         InventarioCategoria @default(OUTRO)
  estado            InventarioEstado    @default(BOM)
  numero_serie      String?
  codigo_patrimonio String?             @unique // código interno da igreja
  marca             String?
  modelo            String?
  cor               String?

  // Estoque
  quantidade_total      Int @default(1)
  quantidade_disponivel Int @default(1)

  // Aquisição
  data_aquisicao  DateTime?
  valor_aquisicao Float?
  fornecedor      String?
  nota_fiscal     String?

  // Garantia
  tem_garantia      Boolean   @default(false)
  garantia_validade DateTime?
  garantia_info     String? // nome da assistência, contrato, etc.

  // Localização física
  localizacao String? // ex: "Sala de Louvor", "Armazém"

  // Foto
  foto_url String?

  // Dono — pode ser departamento, grupo ou membro (apenas um)
  dono_tipo            String? // "DEPARTAMENTO" | "GRUPO" | "MEMBRO" | "IGREJA"
  dono_departamento_id Int?
  dono_grupo_id        Int?
  dono_membro_id       Int?

  // Metadados
  ativo      Boolean  @default(true)
  notas      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  tenant            Tenant                @relation(fields: [tenant_id], references: [id])
  congregacao       Congregacao?          @relation(fields: [congregacao_id], references: [id])
  dono_departamento Departamento?         @relation(fields: [dono_departamento_id], references: [id])
  dono_grupo        Grupo?                @relation(fields: [dono_grupo_id], references: [id])
  dono_membro       Membro?               @relation(fields: [dono_membro_id], references: [id])
  movimentos        MovimentoInventario[]

  @@index([tenant_id])
  @@index([categoria])
  @@index([dono_departamento_id])
  @@index([dono_grupo_id])
  @@index([dono_membro_id])
  @@map("inventario_itens")
}

// ── MOVIMENTOS / HISTÓRICO ────────────────────────────────────────────────────

model MovimentoInventario {
  id                    Int           @id @default(autoincrement())
  tenant_id             Int
  congregacao_id        Int?
  item_id               Int
  tipo                  MovimentoTipo
  quantidade            Int           @default(1)
  data                  DateTime      @default(now())
  responsavel           String? // nome ou ID de quem fez a movimentação
  destino               String? // para empréstimos: nome/local de destino
  data_retorno_prevista DateTime? // para empréstimos
  data_retorno_real     DateTime? // quando voltou
  observacao            String?
  created_at            DateTime      @default(now())

  item        ItemInventario @relation(fields: [item_id], references: [id], onDelete: Cascade)
  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  congregacao Congregacao?   @relation(fields: [congregacao_id], references: [id])

  @@index([item_id])
  @@index([tenant_id])
  @@map("inventario_movimentos")
}

// ── BOLEIA SOLIDARIA ─────────────────────────────────────────────────────────

model BoleiaOferta {
  id                Int              @id @default(autoincrement())
  tenant_id         Int
  motorista_id      Int
  evento_id         Int?
  data_hora_saida   DateTime
  endereco_partida  String
  zona_partida      String?          // Bairro/zona visivel na listagem (privacidade)
  latitude          Float?
  longitude         Float?
  vagas_total       Int
  nota              String?
  recorrente        Boolean          @default(false)  // Repetir semanalmente
  status            String           @default("ATIVA") // ATIVA, CANCELADA, CONCLUIDA
  criado_em         DateTime         @default(now())

  tenant            Tenant           @relation(fields: [tenant_id], references: [id])
  motorista         Membro           @relation("MotoristaOferta", fields: [motorista_id], references: [id])
  evento            Evento?          @relation(fields: [evento_id], references: [id])
  reservas          BoleiaReserva[]

  @@index([tenant_id])
  @@index([motorista_id])
  @@index([evento_id])
  @@index([data_hora_saida])
  @@map("boleia_ofertas")
}

model BoleiaReserva {
  id              Int            @id @default(autoincrement())
  tenant_id       Int
  oferta_id       Int
  passageiro_id   Int
  status          String         @default("CONFIRMADA") // CONFIRMADA, CANCELADA
  criado_em       DateTime       @default(now())

  tenant          Tenant         @relation(fields: [tenant_id], references: [id])
  oferta          BoleiaOferta   @relation(fields: [oferta_id], references: [id], onDelete: Cascade)
  passageiro      Membro         @relation("PassageiroReserva", fields: [passageiro_id], references: [id])

  @@unique([oferta_id, passageiro_id])
  @@index([tenant_id])
  @@index([passageiro_id])
  @@map("boleia_reservas")
}

// ── SISTEMA DE VENDAS INTERNO (Cantina) ──────────────────────────────────────

model CategoriaCantina {
  id          Int               @id @default(autoincrement())
  tenant_id   Int
  nome        String
  ordem       Int               @default(0)    // Para ordenar no menu
  ativa       Boolean           @default(true)
  criado_em   DateTime          @default(now())

  tenant      Tenant            @relation(fields: [tenant_id], references: [id])
  produtos    ProdutoCantina[]

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@map("cantina_categorias")
}

model ProdutoCantina {
  id              Int                @id @default(autoincrement())
  tenant_id       Int
  categoria_id    Int?
  nome            String
  preco           Float
  imagem_url      String?
  stock           Int                @default(0)
  stock_minimo    Int                @default(0)     // Alerta quando stock <= stock_minimo
  controla_stock  Boolean            @default(true)
  disponivel      Boolean            @default(true)  // Visivel no menu/POS
  promocoes       Json?              // [{ quantidade: 2, preco_total: 5.00 }]
  criado_em       DateTime           @default(now())
  atualizado_em   DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenant_id], references: [id])
  categoria       CategoriaCantina?  @relation(fields: [categoria_id], references: [id])
  itensTransacao  ItemTransacaoCantina[]
  itensEncomenda  ItemPreEncomenda[]
  itensCardapio   CardapioItem[]

  @@index([tenant_id])
  @@index([categoria_id])
  @@map("cantina_produtos")
}

model SaldoCantina {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  membro_id       Int      @unique   // 1 saldo por membro
  saldo           Float    @default(0)
  limite_diario   Float?             // null = sem limite
  limite_semanal  Float?             // null = sem limite
  atualizado      DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  membro      Membro   @relation(fields: [membro_id], references: [id])

  @@index([tenant_id])
  @@map("cantina_saldos")
}

model TransacaoCantina {
  id            Int                    @id @default(autoincrement())
  tenant_id     Int
  membro_id     Int?                   // Null = venda avulsa (nao-membro)
  tipo          String                 // RECARGA, CONSUMO, ESTORNO
  valor         Float                  // Positivo para recarga, negativo para consumo
  saldo_apos    Float                  // Saldo apos esta transacao
  descricao     String?
  forma_pagamento String              @default("CREDITOS") // CREDITOS, DINHEIRO, MBWAY, TRANSFERENCIA
  operador_id   Int?                   // Quem operou (admin/operador do POS)
  turno_id      Int?                   // Turno em que a venda foi feita
  criado_em     DateTime               @default(now())

  tenant        Tenant                 @relation(fields: [tenant_id], references: [id])
  membro        Membro?                @relation(fields: [membro_id], references: [id])
  turno         TurnoCantina?          @relation(fields: [turno_id], references: [id])
  itens         ItemTransacaoCantina[]

  @@index([tenant_id])
  @@index([membro_id])
  @@index([turno_id])
  @@index([criado_em])
  @@map("cantina_transacoes")
}

model ItemTransacaoCantina {
  id              Int                @id @default(autoincrement())
  transacao_id    Int
  produto_id      Int
  quantidade      Int
  preco_unitario  Float

  transacao       TransacaoCantina   @relation(fields: [transacao_id], references: [id], onDelete: Cascade)
  produto         ProdutoCantina     @relation(fields: [produto_id], references: [id])

  @@index([transacao_id])
  @@map("cantina_itens_transacao")
}

model TurnoCantina {
  id                    Int                  @id @default(autoincrement())
  tenant_id             Int
  operador_id           Int
  abertura_em           DateTime             @default(now())
  fecho_em              DateTime?
  valor_inicial         Float                @default(0)   // Dinheiro no caixa ao abrir
  valor_final_esperado  Float?                              // Calculado pelo sistema ao fechar
  valor_final_real      Float?                              // Declarado pelo operador
  diferenca             Float?                              // Real - Esperado
  observacao            String?
  status                String               @default("ABERTO") // ABERTO, FECHADO

  tenant                Tenant               @relation(fields: [tenant_id], references: [id])
  operador              Membro               @relation("OperadorTurno", fields: [operador_id], references: [id])
  transacoes            TransacaoCantina[]

  @@index([tenant_id])
  @@index([operador_id])
  @@map("cantina_turnos")
}

model FiadoCantina {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  membro_id       Int
  valor_devido    Float
  transacao_id    Int?     // Referencia a transacao que gerou a divida
  descricao       String?
  status          String   @default("PENDENTE") // PENDENTE, LIQUIDADO
  criado_em       DateTime @default(now())
  liquidado_em    DateTime?

  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  membro          Membro   @relation(fields: [membro_id], references: [id])

  @@index([tenant_id])
  @@index([membro_id])
  @@map("cantina_fiados")
}

// ── PRE-ENCOMENDAS (Cantina) ─────────────────────────────────────────────────

model PreEncomendaCantina {
  id            Int                      @id @default(autoincrement())
  tenant_id     Int
  membro_id     Int
  evento_id     Int
  total         Float
  pago          Boolean                  @default(false)  // true se saldo ja foi debitado
  status        String                   @default("PENDENTE") // PENDENTE, CONFIRMADA, ENTREGUE, CANCELADA
  criado_em     DateTime                 @default(now())
  entregue_em   DateTime?
  cancelado_em  DateTime?

  tenant        Tenant                   @relation(fields: [tenant_id], references: [id])
  membro        Membro                   @relation(fields: [membro_id], references: [id])
  evento        Evento                   @relation(fields: [evento_id], references: [id])
  itens         ItemPreEncomenda[]

  @@index([tenant_id])
  @@index([membro_id])
  @@index([evento_id])
  @@map("cantina_pre_encomendas")
}

model ItemPreEncomenda {
  id              Int                  @id @default(autoincrement())
  encomenda_id    Int
  produto_id      Int
  quantidade      Int
  preco_unitario  Float

  encomenda       PreEncomendaCantina  @relation(fields: [encomenda_id], references: [id], onDelete: Cascade)
  produto         ProdutoCantina       @relation(fields: [produto_id], references: [id])

  @@index([encomenda_id])
  @@map("cantina_itens_pre_encomenda")
}

// ── CARDAPIO DO DIA (Cantina) ────────────────────────────────────────────────

model CardapioCantina {
  id          Int            @id @default(autoincrement())
  tenant_id   Int
  evento_id   Int            @unique  // 1 cardapio por evento
  nome        String?                 // Ex: "Menu Domingo Especial"
  criado_em   DateTime       @default(now())

  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  evento      Evento         @relation(fields: [evento_id], references: [id])
  itens       CardapioItem[]

  @@index([tenant_id])
  @@map("cantina_cardapios")
}

model CardapioItem {
  id                    Int              @id @default(autoincrement())
  cardapio_id           Int
  produto_id            Int
  preco_especial        Float?           // Preco diferente para este evento (null = preco normal)
  quantidade_disponivel Int?             // Limite de encomendas (null = sem limite)

  cardapio        CardapioCantina  @relation(fields: [cardapio_id], references: [id], onDelete: Cascade)
  produto         ProdutoCantina   @relation(fields: [produto_id], references: [id])

  @@unique([cardapio_id, produto_id])
  @@index([cardapio_id])
  @@map("cantina_cardapio_itens")
}

// ── ASSISTENCIA SOCIAL ───────────────────────────────────────────────────────

model ItemAssistenciaSocial {
  id          Int                      @id @default(autoincrement())
  tenant_id   Int
  nome        String
  categoria   String                   // ALIMENTO, HIGIENE, VESTUARIO, OUTRO
  unidade     String                   @default("unidade") // unidade, kg, litro, peca
  stock       Int                      @default(0)
  stock_minimo Int                     @default(0)
  criado_em   DateTime                 @default(now())

  tenant      Tenant                   @relation(fields: [tenant_id], references: [id])
  movimentos  MovimentoAssistencia[]

  @@index([tenant_id])
  @@map("assistencia_itens")
}

model MovimentoAssistencia {
  id              Int                    @id @default(autoincrement())
  tenant_id       Int
  item_id         Int
  tipo            String                 // DOACAO_RECEBIDA, ENTREGA_FAMILIA, ENTREGA_ENTIDADE, REPASSE_CANTINA
  quantidade      Int
  destinatario    String?                // Nome da familia/entidade que recebeu
  observacao      String?
  registrado_por  Int?                   // Membro que registou
  criado_em       DateTime               @default(now())

  tenant          Tenant                 @relation(fields: [tenant_id], references: [id])
  item            ItemAssistenciaSocial  @relation(fields: [item_id], references: [id])

  @@index([tenant_id])
  @@index([item_id])
  @@map("assistencia_movimentos")
}

// ── GESTAO FINANCEIRA — FUNDOS, DESPESAS, ORCAMENTO ──────────────────────────

model FundoFinanceiro {
  id              Int                    @id @default(autoincrement())
  tenant_id       Int
  nome            String                 // Ex: "Fundo Geral", "Construcao", "Missoes"
  descricao       String?
  tipo            String                 @default("CUSTOM") // GERAL, CONSTRUCAO, MISSOES, SOCIAL, CANTINA, CUSTOM
  restrito        Boolean                @default(false) // true = dinheiro so pode ser usado para este fim
  saldo_atual     Float                  @default(0)
  ativo           Boolean                @default(true)
  criado_em       DateTime               @default(now())

  tenant          Tenant                 @relation(fields: [tenant_id], references: [id])
  contribuicoes   Contribuicao[]
  lancamentos     LancamentoFinanceiro[]
  despesas        DespesaFinanceira[]
  orcamentos      Orcamento[]
  categoriasOrcamento CategoriaOrcamento[]
  transferenciasOrigem  TransferenciaFundo[] @relation("FundoOrigem")
  transferenciasDestino TransferenciaFundo[] @relation("FundoDestino")

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@map("financeiro_fundos")
}

model CategoriaOrcamento {
  id          Int               @id @default(autoincrement())
  tenant_id   Int
  fundo_id    Int
  nome        String            // Ex: "Aluguer", "Eletricidade", "Material"
  criado_em   DateTime          @default(now())

  tenant      Tenant            @relation(fields: [tenant_id], references: [id])
  fundo       FundoFinanceiro   @relation(fields: [fundo_id], references: [id])
  despesas    DespesaFinanceira[]
  orcamentos  Orcamento[]

  @@unique([fundo_id, nome])
  @@index([tenant_id])
  @@map("financeiro_categorias_orcamento")
}

model DespesaFinanceira {
  id              Int                @id @default(autoincrement())
  tenant_id       Int
  fundo_id        Int
  categoria_id    Int?
  descricao       String
  valor           Float
  data            DateTime           @default(now())
  forma_pagamento String?
  fornecedor      String?
  comprovante_url String?
  submetido_por   Int                // Membro que submeteu
  aprovado_por    Int?               // Membro que aprovou
  status          String             @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA, PAGA
  observacao      String?
  criado_em       DateTime           @default(now())

  tenant          Tenant             @relation(fields: [tenant_id], references: [id])
  fundo           FundoFinanceiro    @relation(fields: [fundo_id], references: [id])
  categoria       CategoriaOrcamento? @relation(fields: [categoria_id], references: [id])

  @@index([tenant_id])
  @@index([fundo_id])
  @@index([status])
  @@map("financeiro_despesas")
}

model Orcamento {
  id              Int                @id @default(autoincrement())
  tenant_id       Int
  fundo_id        Int
  categoria_id    Int
  ano             Int
  mes             Int?               // null = orcamento anual
  valor_previsto  Float
  criado_em       DateTime           @default(now())

  tenant          Tenant             @relation(fields: [tenant_id], references: [id])
  fundo           FundoFinanceiro    @relation(fields: [fundo_id], references: [id])
  categoria       CategoriaOrcamento @relation(fields: [categoria_id], references: [id])

  @@unique([fundo_id, categoria_id, ano, mes])
  @@index([tenant_id])
  @@map("financeiro_orcamentos")
}

model TransferenciaFundo {
  id              Int              @id @default(autoincrement())
  tenant_id       Int
  fundo_origem_id Int
  fundo_destino_id Int
  valor           Float
  motivo          String
  aprovado_por    Int?
  status          String           @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA
  criado_em       DateTime         @default(now())

  tenant          Tenant           @relation(fields: [tenant_id], references: [id])
  fundoOrigem     FundoFinanceiro  @relation("FundoOrigem", fields: [fundo_origem_id], references: [id])
  fundoDestino    FundoFinanceiro  @relation("FundoDestino", fields: [fundo_destino_id], references: [id])

  @@index([tenant_id])
  @@map("financeiro_transferencias")
}

// ── RECIBOS FISCAIS (IRS) ────────────────────────────────────────────────────

model ReciboFiscal {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  membro_id       Int
  ano             Int
  valor_total     Float    // Soma das contribuicoes dedutiveis no ano
  numero_recibo   String?  // Numero sequencial do recibo
  emitido_em      DateTime @default(now())
  dados_igreja    Json?    // { nif, nome, morada } snapshot no momento da emissao
  dados_membro    Json?    // { nif, nome, morada } snapshot no momento da emissao

  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  membro          Membro   @relation(fields: [membro_id], references: [id])

  @@unique([tenant_id, membro_id, ano])
  @@index([tenant_id])
  @@map("financeiro_recibos")
}
